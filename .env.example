VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Amazon Associates affiliate tag (optional — links work without it, tag adds commission)
# US tag:  yourname-20        → routes to amazon.com
# UK tag:  yourname-21        → routes to amazon.co.uk
# IN tag:  yourname-22        → routes to amazon.in
# Set whichever market you're targeting; the currency toggle determines which store is used.
VITE_AMAZON_AFFILIATE_TAG=your-tag-20

# Unsplash API key — enables real perfume bottle images on every card and the SOTD banner.
# Get a free key at https://unsplash.com/developers (create app → copy "Access Key").
# Without this key cards display their gradient backgrounds — the site still looks great.
VITE_UNSPLASH_ACCESS_KEY=your-unsplash-access-key
